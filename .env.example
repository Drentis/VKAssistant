# VKAssistant - Переменные окружения
# Скопируйте этот файл в .env и заполните значениями

# ID сообщества ВКонтакте (отрицательное число, получить в управлении сообществом)
VK_GROUP_ID=-123456789

# Токен доступа сообщества VK (получить в Управление сообществом -> Работа с API)
VK_TOKEN=your_vk_token_here

# OpenWeatherMap API ключ (получить на https://openweathermap.org/api, необязательно)
WEATHER_API_KEY=your_weather_api_key_here

# VK ID администратора (положительное число, получить через vk.com/foaf.php?id=YOUR_ID, необязательно)
ADMIN_ID=123456789
